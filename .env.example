VITE_API_BASE_URL=
VITE_AI_API_BASE_URL=
VITE_CAPTURE_API_BASE_URL=
VITE_KNOWLEDGE_API_BASE_URL=
VITE_SEARCH_API_BASE_URL=
VITE_COMPETITOR_API_BASE_URL=

# Backend-only Workflow Agent provider settings.
# Keep these out of frontend code. Vite will only expose VITE_* variables.
WORKFLOW_AGENT_PROVIDER=auto
WORKFLOW_AGENT_FALLBACK=deterministic
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4.1-mini
OPENAI_API_SURFACE=responses
OPENAI_TIMEOUT_MS=600000

# 本地 Mac 已配置 Codex / CC Switch 时，可保留项目默认 codex-cli 通道：
# WORKFLOW_AGENT_PROVIDER=codex-cli
# CODEX_DEFAULT_MODEL=gpt-5.5
# CODEX_TIMEOUT_MS=600000

# 如需让后端读取 Codex / CC Switch 当前上游 HTTP 模型：
# WORKFLOW_AGENT_PROVIDER=codex-proxy
# CODEX_CONFIG_PATH=/Users/you/.codex/config.toml
# CODEX_AUTH_PATH=/Users/you/.codex/auth.json
# CODEX_CC_SWITCH_DB_PATH=/Users/you/.cc-switch/cc-switch.db

# Linux 部署需要配置 Chrome/Chromium 路径。
CHROME_EXECUTABLE=
