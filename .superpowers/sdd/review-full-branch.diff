+test('compiles relay capture tasks and classifies capture diagnostics', async () => {
+  const { analyzeCaptureUrl } = await import('../backend/services/capture-url-analyzer.js')
+  const { matchCaptureTemplate } = await import('../backend/services/capture-template-matcher.js')
+  const { compileCaptureTask } = await import('../backend/services/capture-compiler.js')
+  const { classifyCaptureDiagnostics } = await import('../backend/services/capture-diagnostics.js')
+
+  const analysis = analyzeCaptureUrl({
+    url: 'https://example.com/app/home',
+    authMode: 'browser'
+  })
+  const templateMatch = matchCaptureTemplate({ analysis, authMode: 'browser' })
+  const compiled = compileCaptureTask({
+    payload: {
+      projectId: 'project-flow',
+      url: 'https://example.com/app/home',
+      authMode: 'browser',
+      sessionId: 'session-1'
+    },
+    analysis,
+    templateMatch
+  })
+
+  assert.equal(compiled.taskType, 'web-capture')
+  assert.equal(compiled.templateId, 'generic-saas-dashboard')
+  assert.equal(compiled.auth.mode, 'browser')
+  assert.equal(compiled.execution.waitUntil, 'networkidle')
+  assert.equal(compiled.artifacts.domSnapshot, true)
+
+  const blocked = classifyCaptureDiagnostics({
+    compiledTask: compiled,
+    captureResult: {
+      url: compiled.source.url,
+      singleFileHtml: '<html><body><h1>405 异常访问</h1></body></html>',
+      staticHtml: '',
+      layoutNodes: [],
+      raw: {
+        fetchError: '目标网页未能完整抓取',
+        screenshotCaptured: true,
+        singleFileCaptured: true,
+        layoutNodeCount: 0
+      }
+    }
+  })
+
+  assert.equal(blocked.status, 'blocked')
+  assert.equal(blocked.diagnostics[0].code, 'ANTI_BOT_SUSPECTED')
+  assert.ok(blocked.recoveryActions.includes('打开授权浏览器'))
+
+  const loginRequired = classifyCaptureDiagnostics({
+    compiledTask: {
+      ...compiled,
+      auth: { ...compiled.auth, mode: 'public' }
+    },
+    captureResult: {
+      url: compiled.source.url,
+      singleFileHtml: '<html><body><div>login required</div></body></html>',
+      staticHtml: '',
+      layoutNodes: [{ id: 'n1' }],
+      raw: {
+        fetchError: '',
+        layoutNodeCount: 1
+      }
+    }
+  })
+  assert.equal(loginRequired.status, 'blocked')
+  assert.deepEqual(loginRequired.diagnostics.map((item) => item.code), ['LOGIN_REQUIRED'])
+
+  const cookieExpired = classifyCaptureDiagnostics({
+    compiledTask: compiled,
+    captureResult: {
+      url: compiled.source.url,
+      singleFileHtml: '<html></html>',
+      staticHtml: '',
+      layoutNodes: [{ id: 'n2' }],
+      raw: {
+        fetchError: '',
+        fetchStatus: 403,
+        layoutNodeCount: 1
+      }
+    }
+  })
+  assert.equal(cookieExpired.status, 'blocked')
+  assert.deepEqual(cookieExpired.diagnostics.map((item) => item.code), ['COOKIE_EXPIRED'])
+
+  const domNotRestorable = classifyCaptureDiagnostics({
+    compiledTask: compiled,
+    captureResult: {
+      url: compiled.source.url,
+      singleFileHtml: '',
+      staticHtml: '',
+      layoutNodes: [],
+      raw: {
+        fetchError: '',
+        layoutNodeCount: 0
+      }
+    }
+  })
+  assert.equal(domNotRestorable.status, 'blocked')
+  assert.deepEqual(domNotRestorable.diagnostics.map((item) => item.code), ['DOM_NOT_RESTORABLE'])
+
+  const hasTopLevelLayoutNodes = classifyCaptureDiagnostics({
+    compiledTask: compiled,
+    captureResult: {
+      url: compiled.source.url,
+      singleFileHtml: '',
+      staticHtml: '',
+      layoutNodes: [{ id: 'top-level-only' }],
