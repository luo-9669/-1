# 流程通完整部署环境变量模板
# 复制为服务器环境变量或 .env.production；不要把真实 key 提交到 Git。

# 服务端口
PORT=5599
FRONTEND_PORT=5588

# 前端访问后端的地址。生产构建时建议填公网后端地址。
VITE_API_BASE_URL=https://your-api.example.com
VITE_AI_API_BASE_URL=https://your-api.example.com
VITE_CAPTURE_API_BASE_URL=https://your-api.example.com
VITE_KNOWLEDGE_API_BASE_URL=https://your-api.example.com
VITE_SEARCH_API_BASE_URL=https://your-api.example.com
VITE_COMPETITOR_API_BASE_URL=https://your-api.example.com

# 推荐的服务器部署方式：后端直接调用 OpenAI-compatible 模型。
WORKFLOW_AGENT_PROVIDER=openai-compatible
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4.1-mini
OPENAI_API_SURFACE=responses
OPENAI_TIMEOUT_MS=600000

# 本地 Mac / Codex 环境可继续使用 codex-cli，不需要写 OPENAI_API_KEY。
# WORKFLOW_AGENT_PROVIDER=codex-cli
# CODEX_DEFAULT_MODEL=gpt-5.5
# CODEX_TIMEOUT_MS=600000

# 如果要让后端读取当前 Codex / CC Switch 关联的上游模型，可显式选择 codex-proxy。
# 适合部署在同一台已经配置好 ~/.codex 或 ~/.cc-switch 的机器上。
# WORKFLOW_AGENT_PROVIDER=codex-proxy
# CODEX_CONFIG_PATH=/home/app/.codex/config.toml
# CODEX_AUTH_PATH=/home/app/.codex/auth.json
# CODEX_CC_SWITCH_DB_PATH=/home/app/.cc-switch/cc-switch.db

# Linux 服务器需要安装 Chrome/Chromium，并配置可执行路径。
CHROME_EXECUTABLE=/usr/bin/chromium-browser
# 或：
# PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/bin/chromium-browser

# 可选：持久化 workspace 存储路径。
# WORKSPACE_STORE_FILE=/data/liuchengtong/workspace.local.json
# WORKFLOW_GENERATED_IMAGE_DIR=/data/liuchengtong/generated-images
# WORKSPACE_MATERIAL_PREVIEW_DIR=/data/liuchengtong/material-previews
