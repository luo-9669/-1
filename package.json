{
  "name": "liuchengtong-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm --prefix frontend run dev --",
    "api": "npm --prefix backend run api --",
    "api:restart": "npm --prefix backend run api:restart --",
    "dev:all": "node scripts/start-dev.mjs",
    "start:all": "node scripts/start-dev.mjs",
    "test": "node tests/workflows.test.mjs",
