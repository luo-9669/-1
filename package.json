{
  "name": "liuchengtong-workspace",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter liuchengtong-frontend run dev",
    "api": "pnpm --filter liuchengtong-backend run api",
    "api:restart": "pnpm --filter liuchengtong-backend run api:restart",
    "dev:all": "node scripts/start-dev.mjs",
    "start:all": "node scripts/start-dev.mjs",
    "test": "node --test tests/workflow-agent-actions.test.mjs backend/routes/workspace.test.js tests/system-skills.test.mjs tests/web-evidence-search.test.mjs",
    "build": "pnpm --filter liuchengtong-frontend run build",
    "preview": "pnpm --filter liuchengtong-frontend run preview",
    "install:all": "pnpm install",
    "install:browsers": "pnpm --filter liuchengtong-backend exec playwright-core -- install chromium",
    "install:browsers:deps": "pnpm --filter liuchengtong-backend exec playwright-core -- install --with-deps chromium"
  }
}
